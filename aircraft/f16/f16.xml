    <flight_control name="FCS: F16">
        <!--
            This is a fly-by-wire flight control system based on the FCS given in
            the book by Stevens and Lewis, "Aircraft Control and Simulation, 2nd. Ed."
            The FCS is composed of several channels that are listed below.
        -->

        <!--
        #####################################################################
        #                             PITCH CHANNEL
        #####################################################################
        -->
        <channel name="Pitch">
            <!--
                This is the longitudinal axis flight control system. It is a
                pitch-rate command system when the landing gear handle is up. When
                the gear handle is down, the longitudinal FCS reverts to a more
                conventional stability augmentation system. Also, when the gear
                is down, an angle-of-attack limiter provides stall protection and
                a speed-dependent gain schedule is introduced on the stick input.
            -->
            <!--
                The elevator command is limited to 44% of the full negative
                (trailing edge up) direction. This limits the aircraft to a
                maximum of 9 g's positive, and 4 g's negative.
            -->
            <summer name="Elevator Command Limiter">
                <input> fcs/pitch-trim-cmd-norm </input>
                <input> fcs/pitch-stick-cmd-norm </input>
                <clipto>
                    <min> -0.44 </min>
                    <max>  1.00 </max>
                </clipto>
            </summer>

            <!-- Stick Force Sensor -->
            <kinematic name="Pitch Stick Block">
                <input> fcs/pitch-trim-cmd-norm </input>
                <input> fcs/pitch-stick-cmd-norm </input>
                <clipto>
                    <min> -0.44 </min>
                    <max>  1.00 </max>
                </clipto>
            </kinematic>

            <!--
                The following PID controller provides for g-load control as a
                function of pitch rate.
            -->
            <pid name="G-load PID">
                <input> fcs/g-load-command </input>
                <feedback> accelerations/nz-pilot-fps_sec </feedback>
                <kp> 0.4 </kp>
                <ki> 0.1 </ki>
                <kd> 0.0 </kd>
                <clipto>
                    <min> -2.0 </min>
                    <max>  2.0 </max>
                </clipto>
            </pid>

            <!-- Pitch rate feedback -->
            <pure_gain name="Pitch Rate Feedback">
                <input> velocities/q-rad_sec </input>
                <gain> -1.0 </gain>
            </pure_gain>

            <summer name="Pitch Rate Summing Junction">
                <input> fcs/pitch-stick-command </input>
                <input> fcs/g-load-pid </input>
                <input> fcs/pitch-rate-feedback </input>
            </summer>

            <!--
                When angle of attack nears 30 degrees, the following controller
                commands full pitch down to prevent stall.
            -->
            <pid name="Alpha limiter">
                <input> aero/alpha-rad </input>
                <feedback> 0.5235 </feedback>
                <kp> -1.0 </kp>
                <ki>  0.0 </ki>
                <kd>  0.0 </kd>
                <clipto>
                    <min> -1.0 </min>
                    <max>  0.0 </max>
                </clipto>
            </pid>

            <!-- Elevator command summing junction -->
            <summer name="Elevator command">
                <input> fcs/pitch-rate-summing-junction </input>
                <input> fcs/alpha-limiter </input>
                <clipto>
                    <min> -25.0 </min>
                    <max>  25.0 </max>
                </clipto>
            </summer>

            <!-- Elevator actuator -->
            <actuator name="Elevator">
                <input> fcs/elevator-command </input>
                <lag> 20.0 </lag>
                <clipto>
                    <min> -25.0 </min>
                    <max>  25.0 </max>
                </clipto>
            </actuator>
        </channel>

        <!--
        #####################################################################
        #                             ROLL CHANNEL
        #####################################################################
        -->
        <channel name="Roll">
            <!--
                This is the lateral axis flight control system. It is a roll-rate
                command system.
            -->
            <!-- Stick Force Sensor -->
            <scheduled_gain name="Stick Force Gain">
                <input> fcs/roll-stick-cmd-norm </input>
                <gain>
                    <table>
                        <independent> velocities/mach </independent>
                        <dependent>
                             0.2
                             0.4
                             0.8
                             1.0
                        </dependent>
                    </table>
                </gain>
            </scheduled_gain>

            <!-- The following PID controller provides for roll rate control -->
            <pid name="Roll Rate PID">
                <input> fcs/stick-force-gain </input>
                <feedback> velocities/p-rad_sec </feedback>
                <kp> 1.0 </kp>
                <ki> 0.0 </ki>
                <kd> 0.0 </kd>
                <clipto>
                    <min> -1.0 </min>
                    <max>  1.0 </max>
                </clipto>
            </pid>

            <!-- Aileron command -->
            <summer name="Aileron Command">
                <input> fcs/roll-trim-cmd-norm </input>
                <input> fcs/roll-rate-pid </input>
                <clipto>
                    <min> -21.5 </min>
                    <max>  21.5 </max>
                </clipto>
            </summer>

            <!-- Aileron actuator -->
            <actuator name="Aileron">
                <input> fcs/aileron-command </input>
                <lag> 20.0 </lag>
                <clipto>
                    <min> -21.5 </min>
                    <max>  21.5 </max>
                </clipto>
            </actuator>

            <aerosurface_scale name="Aileron effectiveness">
                <input> fcs/aileron </input>
                <domain>
                    <min> -21.5 </min>
                    <max>  21.5 </max>
                </domain>
                <range>
                    <min> -1.0 </min>
                    <max>  1.0 </max>
                </range>
            </aerosurface_scale>

            <aerosurface_scale name="Aileron to speedbrake interconnect">
                <input> fcs/aileron-effectiveness </input>
                <domain>
                    <min> -1.0 </min>
                    <max>  1.0 </max>
                </domain>
                <range>
                    <min> 0.25 </min>
                    <max> 0.25 </max>
                </range>
            </aerosurface_scale>
        </channel>

        <!--
        #####################################################################
        #                             YAW CHANNEL
        #####################################################################
        -->
        <channel name="Yaw">
            <!--
                This is the directional axis flight control system.
            -->
            <!-- Yaw rate feedback -->
            <pure_gain name="Yaw Rate Feedback">
                <input> velocities/r-rad_sec </input>
                <gain> -1.0 </gain>
            </pure_gain>

            <!-- Sideslip feedback -->
            <pure_gain name="Sideslip Feedback">
                <input> aero/beta-rad </input>
                <gain> -1.0 </gain>
            </pure_gain>

            <!-- Rudder command -->
            <summer name="Rudder Command">
                <input> fcs/yaw-trim-cmd-norm </input>
                <input> fcs/pedals-cmd-norm </input>
                <input> fcs/yaw-rate-feedback </input>
                <input> fcs/sideslip-feedback </input>
                <clipto>
                    <min> -30.0 </min>
                    <max>  30.0 </max>
                </clipto>
            </summer>

            <scheduled_gain name="Rudder Authority Limiter">
                <input> fcs/rudder-command </input>
                <gain>
                    <table>
                        <independent> velocities/mach </independent>
                        <dependent>
                             0.2
                             0.4
                             0.8
                             1.0
                        </dependent>
                    </table>
                </gain>
            </scheduled_gain>

            <!-- Rudder actuator -->
            <actuator name="Rudder">
                <input> fcs/rudder-authority-limiter </input>
                <lag> 20.0 </lag>
                <clipto>
                    <min> -30.0 </min>
                    <max>  30.0 </max>
                </clipto>
            </actuator>
        </channel>

        <!--
        #####################################################################
        #                             FLAPS CHANNEL
        #####################################################################
        -->
        <channel name="Flaps">
            <!--
                Trailing edge flap deployment is automatic, based on airspeed.
            -->
            <scheduled_gain name="Trailing Edge Flap Command">
                <input> velocities/vc-kts </input>
                <gain>
                    <table>
                        <independent> 0   250 </independent>
                        <dependent>   1.0 0.0 </dependent>
                    </table>
                </gain>
            </scheduled_gain>

            <actuator name="Trailing Edge Flap">
                <input> fcs/trailing-edge-flap-command </input>
                <lag> 2.0 </lag>
                <clipto>
                    <min> 0.0 </min>
                    <max> 1.0 </max>
                </clipto>
            </actuator>

            <!--
                Leading edge flap deployment is automatic, based on angle of
                attack and gear state.
            -->
            <scheduled_gain name="LE Flap Command from Alpha">
                <input> aero/alpha-rad </input>
                <gain>
                    <table>
                        <independent> 0.0 0.523 </independent>
                        <dependent>   0.0 1.0   </dependent>
                    </table>
                </gain>
            </scheduled_gain>

            <switch name="LE Flap Command Switch">
                <default value="0.0"/>
                <test logic="AND" value="fcs/le-flap-command-from-alpha">
                    gear/gear-pos-norm eq 1
                </test>
            </switch>

            <actuator name="Leading Edge Flap">
                <input> fcs/le-flap-command-switch </input>
                <lag> 2.0 </lag>
                <clipto>
                    <min> 0.0 </min>
                    <max> 1.0 </max>
                </clipto>
            </actuator>
        </channel>

        <!--
        #####################################################################
        #                             SPEEDBRAKE
        #####################################################################
        -->
        <channel name="Speedbrake">
            <!--
                The speedbrake automatically deploys at high alpha to prevent
                deep stall. Also, when the landing gear is extended, the
                speedbrake deflection is reduced to prevent ground strikes.
                The speedbrake can also be controlled manually via a cockpit
                switch.
            -->
            <scheduled_gain name="Alpha Speedbrake">
                <input> aero/alpha-rad </input>
                <gain>
                    <table>
                        <independent> 0.4363 0.5235 </independent>
                        <dependent>   0.0    1.0    </dependent>
                    </table>
                </gain>
            </scheduled_gain>

            <summer name="Speedbrake Summing Junction">
                <input> fcs/alpha-speedbrake </input>
                <input> fcs/speedbrake-cmd-norm </input>
            </summer>

            <switch name="Speedbrake Switch">
                <default value="1.0"/>
                <test logic="AND" value="0.67">
                    gear/gear-pos-norm eq 1
                </test>
            </switch>

            <pure_gain name="Speedbrake Gain">
                <input> fcs/speedbrake-summing-junction </input>
                <gain> fcs/speedbrake-switch </gain>
            </pure_gain>

            <actuator name="Speedbrake">
                <input> fcs/speedbrake-gain </input>
                <lag> 1.0 </lag>
                <clipto>
                    <min> 0.0 </min>
                    <max> 1.0 </max>
                </clipto>
            </actuator>
        </channel>

        <!--
        #####################################################################
        #                             LANDING GEAR
        #####################################################################
        -->
        <channel name="Landing Gear">
            <kinematic name="Gear Position">
                <input> gear/gear-cmd-norm </input>
                <traverse_time> 8 </traverse_time>
                <clipto>
                    <min> 0 </min>
                    <max> 1 </max>
                </clipto>
            </kinematic>
            <kinematic name="Gear Door Position">
                <input> gear/gear-pos-norm </input>
                <function>
                    <table>
                        <independent> 0.0 0.1 0.9 1.0 </independent>
                        <dependent>   0.0 1.0 1.0 0.0 </dependent>
                    </table>
                </function>
                <clipto>
                    <min> 0 </min>
                    <max> 1 </max>
                </clipto>
            </kinematic>
        </channel>

        <!--
        #####################################################################
        #                             HOOK
        #####################################################################
        -->
        <channel name="Hook">
            <kinematic name="Hook Position">
                <input> gear/hook-cmd-norm </input>
                <traverse_time> 2 </traverse_time>
                <clipto>
                    <min> 0 </min>
                    <max> 1 </max>
                </clipto>
            </kinematic>
        </channel>

        <!--
        #####################################################################
        #                             CANOPY
        #####################################################################
        -->
        <channel name="Canopy">
            <kinematic name="Canopy Position">
                <input> simulation/canopy-cmd-norm </input>
                <traverse_time> 5 </traverse_time>
                <clipto>
                    <min> 0 </min>
                    <max> 1 </max>
                </clipto>
            </kinematic>
        </channel>
    </flight_control>

    <aerodynamics>
        <!--
            The aerodynamic data is a function of angle-of-attack,
            sideslip angle, and elevator, aileron, and rudder deflections. The aerodynamic data
            is valid for angles-of-attack from -10 to 45 degrees, and for sideslip angles from
            -30 to 30 degrees.
        -->
        <axis name="DRAG">
            <!-- Ground effect -->
            <function name="aero/function/ground-effect-drag-factor">
                <description>Drag factor due to ground effect</description>
                <product>
                    <property>aero/function/qbar-area</property>
                    <property>aero/cl-squared</property>
                    <property>aero/function/ground-effect-factor</property>
                    <value>-0.063</value>
                </product>
            </function>
            <function name="aero/function/drag-from-alpha">
                <description>Drag from alpha</description>
                <product>
                    <property>aero/function/qbar-area</property>
                    <table name="CDa">
                        <independent>aero/alpha-rad</independent>
                        <dependent>
                            <value ind="-0.3490">  0.0380 </value>
                            <value ind="-0.2618">  0.0230 </value>
                            <value ind=" 0.0000">  0.0160 </value>
                            <value ind=" 0.2618">  0.0230 </value>
                            <value ind=" 0.3490">  0.0380 </value>
                            <value ind=" 0.5236">  0.0800 </value>
                            <value ind=" 0.6981">  0.1500 </value>
                            <value ind=" 0.8727">  0.2400 </value>
